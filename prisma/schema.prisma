// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// Per-shop app settings: brand voice preference and AI generation usage tracking.
model ShopSettings {
  id              String   @id @default(cuid())
  shop            String   @unique
  brandVoice      String   @default("neutral")
  plan            String? // "Starter" | "Growth" | null (free tier)
  generationsUsed Int      @default(0)
  periodStart     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// History of AI generations, used for the usage dashboard.
model GenerationLog {
  id           String   @id @default(cuid())
  shop         String
  productId    String
  productTitle String
  applied      Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([shop])
}

// Pre-launch waitlist signups collected from the marketing landing page.
model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}
